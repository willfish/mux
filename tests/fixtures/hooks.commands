tmux start-server
pane_base_index=$(tmux show-option -gv pane-base-index 2>/dev/null || echo 0)
base_index=$(tmux show-option -gv base-index 2>/dev/null || echo 0)
echo "project start"
tmux has-session -t hooks 2>/dev/null
if [ $? != 0 ]; then
echo "first start"
tmux new-session -d -s hooks -n main -c ~/test
tmux send-keys -t hooks:main.$((pane_base_index+0)) "echo \"main window\"" C-m
tmux select-window -t hooks:main
else
echo "restart"
fi
if [ -z "$TMUX" ]; then
tmux -u attach-session -t hooks
else
tmux -u switch-client -t hooks
fi
echo "exit"
